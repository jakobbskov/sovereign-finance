# Sovereign Finance runtime configuration
# Copy to .env on the runtime host and replace placeholder values.

# Use "production" for live runtime. Use "development" only for local testing.
SOVEREIGN_FINANCE_ENV=production

# Required in production. Must not be CHANGE-ME.
FLASK_SECRET_KEY=replace-with-a-long-random-secret

# Required in production. Must not be CHANGE-ME.
FINANCE_PASSWORD=replace-with-a-strong-login-password

# Use 1 behind HTTPS/reverse proxy. Use 0 only for local plain HTTP testing.
COOKIE_SECURE=1

# Historical/local dev variables. The Docker runtime currently mounts /opt/sovereign-finance/data.
SOVEREIGN_FINANCE_DATA_DIR=/opt/sovereign-finance/data
SOVEREIGN_FINANCE_HOST=127.0.0.1
SOVEREIGN_FINANCE_PORT=5055
